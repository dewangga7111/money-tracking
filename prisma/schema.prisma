generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TbSystem {
  sysCat      String   @map("sys_cat") @db.VarChar(100)
  sysSubCat   String   @map("sys_sub_cat") @db.VarChar(100)
  sysCode     String   @map("sys_code") @db.VarChar(100)
  sysValue    String   @map("sys_value") @db.Text
  description String?  @db.VarChar(255)
  status      Boolean  @default(true)
  createdBy   String?  @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy   String?  @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@id([sysCat, sysSubCat, sysCode])
  @@map("tb_system")
}


model TbRole {
  roleId      String   @id @default(uuid()) @map("role_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  status      Boolean  @default(true)
  createdBy   String?  @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy   String?  @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  users TbUser[]

  @@map("tb_role")
}

model TbHomeSection {
  section   String   @id @db.VarChar(50)
  data      Json     @db.JsonB
  updatedBy String?  @map("updated_by") @db.VarChar(50)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("tb_home_section")
}

model TbUser {
  userId    String   @id @default(uuid()) @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  roleId    String   @map("role_id") @db.Uuid
  status    Boolean  @default(true)
  createdBy String?  @map("created_by") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy String?  @map("updated_by") @db.VarChar(50)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  role TbRole @relation(fields: [roleId], references: [roleId])

  @@map("tb_user")
}
