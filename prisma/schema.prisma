// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; "rhel-openssl-3.0.x" is the engine Vercel's
  // Node.js serverless runtime (Amazon Linux) needs at runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TbSystem {
  sysCat      String   @map("sys_cat") @db.VarChar(100)
  sysSubCat   String   @map("sys_sub_cat") @db.VarChar(100)
  sysCode     String   @map("sys_code") @db.VarChar(100)
  sysValue    String   @map("sys_value") @db.Text
  description String?  @db.VarChar(255)
  status      Boolean  @default(true)
  createdBy   String?  @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy   String?  @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@id([sysCat, sysSubCat, sysCode])
  @@map("tb_system")
}


model TbRole {
  roleId      String   @id @default(uuid()) @map("role_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  status      Boolean  @default(true)
  createdBy   String?  @map("created_by") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy   String?  @map("updated_by") @db.VarChar(50)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  users TbUser[]

  @@map("tb_role")
}


model TbUser {
  userId    String   @id @default(uuid()) @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  roleId    String   @map("role_id") @db.Uuid
  status    Boolean  @default(true)
  createdBy String?  @map("created_by") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy String?  @map("updated_by") @db.VarChar(50)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  role TbRole @relation(fields: [roleId], references: [roleId])

  wallets      TbWallet[]
  categories   TbCategory[]
  transactions TbTransaction[]

  @@map("tb_user")
}

enum WalletType {
  BANK
  E_WALLET
  CASH
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model TbWallet {
  walletId  String     @id @default(uuid()) @map("wallet_id") @db.Uuid
  name      String     @db.VarChar(100)
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(19, 4)
  userId    String     @map("user_id") @db.Uuid
  status    Boolean    @default(true)
  createdBy String?    @map("created_by") @db.VarChar(50)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy String?    @map("updated_by") @db.VarChar(50)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user              TbUser          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  transactionsFrom  TbTransaction[] @relation("WalletFrom")
  transactionsTo    TbTransaction[] @relation("WalletTo")

  @@map("tb_wallet")
}

model TbCategory {
  categoryId String       @id @default(uuid()) @map("category_id") @db.Uuid
  name       String       @db.VarChar(100)
  type       CategoryType
  icon       String?      @db.VarChar(50)
  userId     String       @map("user_id") @db.Uuid
  status     Boolean      @default(true)
  createdBy  String?      @map("created_by") @db.VarChar(50)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy  String?      @map("updated_by") @db.VarChar(50)
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user         TbUser          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  transactions TbTransaction[]

  @@map("tb_category")
}

model TbTransaction {
  transactionId String          @id @default(uuid()) @map("transaction_id") @db.Uuid
  amount        Decimal         @db.Decimal(19, 4)
  date          DateTime        @db.Timestamp(6)
  notes         String?         @db.VarChar(255)
  type          TransactionType
  walletId      String          @map("wallet_id") @db.Uuid
  toWalletId    String?         @map("to_wallet_id") @db.Uuid
  categoryId    String?         @map("category_id") @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  createdBy     String?         @map("created_by") @db.VarChar(50)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedBy     String?         @map("updated_by") @db.VarChar(50)
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user       TbUser      @relation(fields: [userId], references: [userId], onDelete: Cascade)
  wallet     TbWallet    @relation("WalletFrom", fields: [walletId], references: [walletId])
  toWallet   TbWallet?   @relation("WalletTo", fields: [toWalletId], references: [walletId])
  category   TbCategory? @relation(fields: [categoryId], references: [categoryId])

  @@map("tb_transaction")
}
